            </div>
        </div>
    </div>
    <div class="fixed inset-0 z-[1] global-vignette pointer-events-none"></div>
    <!-- TopNavBar -->
    <nav class="fixed top-0 w-full z-50 bg-black/40 backdrop-blur-xl border-b border-white/5">
        <div class="flex justify-between items-center px-8 py-6 max-w-full mx-auto">
            <div class="text-2xl font-black text-white tracking-tighter font-headline">LCG</div>
            <div class="hidden md:flex gap-12">
                <a class="text-violet-300 border-b-2 border-violet-400 pb-1 font-['Epilogue'] font-bold tracking-tight"
                    href="#">Work</a>
                <a class="text-white/70 hover:text-white transition-colors hover:text-violet-300 transition-all duration-300 font-['Epilogue'] font-bold tracking-tight"
                    href="#">Services</a>
                <a class="text-white/70 hover:text-white transition-colors hover:text-violet-300 transition-all duration-300 font-['Epilogue'] font-bold tracking-tight"
                    href="#">Clients</a>
                <a class="text-white/70 hover:text-white transition-colors hover:text-violet-300 transition-all duration-300 font-['Epilogue'] font-bold tracking-tight"
                    href="#">About</a>
            </div>
            <button
                class="bg-primary text-on-primary px-6 py-2.5 rounded-xl font-headline font-bold text-sm scale-95 active:opacity-80 transition-transform">
                Get Started
            </button>
        </div>
    </nav>
    <!-- Hero Section -->
    <section class="relative h-screen w-full overflow-hidden flex items-center justify-center bg-black">
        <!-- Hero Video Background -->
        <div class="video-foreground">
            <iframe allow="autoplay; encrypted-media" frameborder="0"
                src="https://www.youtube.com/embed/4poqZjNTZjI?controls=0&amp;showinfo=0&amp;rel=0&amp;autoplay=1&amp;loop=1&amp;mute=1&amp;playlist=4poqZjNTZjI"></iframe>
        </div>
        <div class="absolute inset-0 scrim-overlay z-[5]"></div>
        <!-- Minimalist Hero Overlay (No Text/Buttons) -->
        <div class="relative z-10 text-center px-4 max-w-5xl invisible">
        </div>
    </section>
    <!-- Client Showcase (Bento Grid) -->
    <section class="py-32 px-8 relative z-10">
        <div class="max-w-7xl mx-auto">
            <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
                <div class="max-w-2xl">
                    <span
                        class="text-secondary font-headline font-bold tracking-widest uppercase text-sm mb-4 block">Proven
                        Impact</span>
                    <h2
                        class="text-4xl md:text-6xl font-headline font-black text-on-surface tracking-tight text-shadow-lg">
                        Our Portfolio</h2>
                </div>
                <button
                    class="text-primary font-body font-semibold flex items-center gap-2 hover:translate-x-2 transition-transform">
                    View all projects <span class="material-symbols-outlined">arrow_forward</span>
                </button>
            </div>
            <!-- Portfolio Grid with New Imagery -->
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 h-auto">
                <!-- Main Featured Project -->
                <div
                    class="md:col-span-8 group relative overflow-hidden rounded-xl bg-surface-container-low h-[500px] md:h-[600px] transition-all duration-500 border border-white/10">
                    <img alt=""
                        class="w-full h-full object-cover opacity-60 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuAOMNhLRttg-mLvOuE_DdoejGlImjc4s9y9GsfdmY_zfkSZ_zF6yfMvoLc29LJOr_cq_mZrqxSDFXTEnJY4QhA8nN1HCw5x0p3K38YeNPTA6ZMQeH75W7XHrEvb1wwFlbKZpLIlQZqqsADAOQgQdc_FKh7Hgp4kdnHrhp8eOkz0kvK6M_IruqEuZlNBc790Crdd5E6zO6HYKQQoeodirjqHVlblib542I_iayILe-JxlPeHC7D5qRSM7Rv-XHXe_sQcunppO03zbhKi" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 p-8">
                        <div class="text-tertiary font-headline font-bold text-sm mb-2">FASHION &amp; EDITORIAL</div>
                        <h3 class="text-3xl font-headline font-bold text-white mb-4">Vogue Collective 2024</h3>
                        <p class="text-on-surface-variant max-w-md">3.2M Impressions in 48 hours through cinematic
                            short-form storytelling.</p>
                    </div>
                </div>
                <!-- New Integrated Grid Project from IMAGE_5 -->
                <div
                    class="md:col-span-4 group relative overflow-hidden rounded-xl bg-surface-container-low h-[500px] md:h-[600px] border border-white/10">
                    <img alt=""
                        class="w-full h-full object-cover opacity-60 group-hover:scale-110 transition-all duration-700"
                        src="https://lh3.googleusercontent.com/aida/ADBb0ujs6N9HB5n2h3FF8Ac_oXqmpDap0XFSLFtNeQFYa4Y3C1A39Ivd9FZtUxk895_Tku9UHmUcm6Ff_qcLU9aQIxRasVBfqxTEnggZMWXIcGblM1L5IhMnjftX3ulWFE8JeKGi4MWyf-uanDDlAAqpTdFoJnl0q1HV8EH44mqL0EtzUxtGrkPcIidZOcJDm1D6vBuZKyXVLmfpJcKahmXVuuiEBXiFGGcj_ccNSOCxJsUOd-fcTaGYV7Fh2UX1jAY1joAkza88MJNrmg" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 p-8">
                        <div class="text-primary font-headline font-bold text-sm mb-2">CONTENT SERIES</div>
                        <h3 class="text-2xl font-headline font-bold text-white mb-2">Wefilm: The Behind-the-Scenes
                            Journey</h3>
                        <p class="text-sm text-on-surface-variant">Defining new visual standards for high-engagement
                            social storytelling.</p>
                    </div>
                </div>
                <div
                    class="md:col-span-6 group relative overflow-hidden rounded-xl bg-surface-container-low h-[400px] border border-white/10">
                    <img alt=""
                        class="w-full h-full object-cover opacity-50 group-hover:scale-110 transition-all duration-700"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuBa5l-58DT9MK4EljIDGe6qkRAGWw6uI8PTxM4OQqlDw1MB4DQzrJgiugQx-Jt6f1MifojpI4ROnQzDqU2SQMWXasaJlT47DqhatoVolx9cSoMieyJ_Q8O6d8zLxTsibBK2R63umcexS1rHgxo4LAwjujtzU5pxjYAJWTc5SWxKEGOSiFyTtaXpgTmNZyHnd4VjtV0o5R5YqnM5zcKG-zi4DYPcr-TnWCpUJgL0JApbuE4fRL6gpivjKeFNWeDeQiQ3uXSMTvrHuNYa" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 p-8">
                        <div class="text-secondary font-headline font-bold text-sm mb-2">GAMING</div>
                        <h3 class="text-2xl font-headline font-bold text-white mb-2">Razer Nexus Launch</h3>
                    </div>
                </div>
                <div
                    class="md:col-span-6 group relative overflow-hidden rounded-xl bg-surface-container-low h-[400px] border border-white/10">
                    <img alt=""
                        class="w-full h-full object-cover opacity-50 group-hover:scale-105 transition-all duration-700"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuDZsexLTlMBXU9O4PUdXn1QmdV8jpRrnpFNH3GyPrYNANW5GM3PrbJjLAvJydy-eOtP5oa64RAIPllrqpbLQjmNo5YeSWdwSdcsycLDvoFZAhxhUtJFpUYpMPJUSImc7RXBLXe2tAGNQWxH5NN78gTOn_bY-mMz6CpeGqXBcPOniDJONah1BEg5hk3L38oKg1LrNNJ8RXqjecz2x8kCi3DYtIkgpz5Q5p3x0xx8HiSv-eQxBGTLG6YtsDz086s_SEB6hc1we09LqSug" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 p-8">
                        <div class="text-tertiary font-headline font-bold text-sm mb-2">LIVE EVENTS</div>
                        <h3 class="text-3xl font-headline font-bold text-white mb-2">Sonic Horizons Tour</h3>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Services Section -->
    <section class="py-32 relative z-10 bg-black/40 backdrop-blur-sm">
        <div class="max-w-7xl mx-auto px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
                <div>
                    <h2
                        class="text-5xl md:text-7xl font-headline font-black text-on-surface mb-16 leading-[0.9] text-shadow-lg">
                        Our <br /><span class="text-primary">Ecosystem</span>
                    </h2>
                    <div class="space-y-16">
                        <div class="group">
                            <div class="flex items-center gap-6 mb-4">
                                <div
                                    class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary border border-primary/20">
                                    <span class="material-symbols-outlined"
                                        style="font-variation-settings: 'FILL' 1;">movie</span>
                                </div>
                                <h3 class="text-2xl font-headline font-bold text-white text-shadow-lg">Cinematic
                                    Production</h3>
                            </div>
                            <p class="text-on-surface-variant font-body leading-relaxed pl-18">
                                4K vertical storytelling that blends the polish of a feature film with the urgency of
                                social media trends.
                            </p>
                        </div>
                        <div class="group">
                            <div class="flex items-center gap-6 mb-4">
                                <div
                                    class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center text-secondary border border-secondary/20">
                                    <span class="material-symbols-outlined"
                                        style="font-variation-settings: 'FILL' 1;">insights</span>
                                </div>
                                <h3 class="text-2xl font-headline font-bold text-white text-shadow-lg">Content Strategy
                                </h3>
                            </div>
                            <p class="text-on-surface-variant font-body leading-relaxed pl-18">
