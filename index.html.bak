<!DOCTYPE html>

<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>LCG | Cinematic Social Media Excellence</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;700;800;900&amp;family=Manrope:wght@300;400;500;600&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-dim": "#0e0e0f",
                        "error": "#ff716c",
                        "secondary-container": "#ae3200",
                        "primary-dim": "#9b4de0",
                        "on-tertiary-fixed-variant": "#665500",
                        "on-primary-fixed": "#2e1065",
                        "secondary-fixed-dim": "#ffb199",
                        "outline": "#767576",
                        "surface-container-lowest": "#000000",
                        "on-secondary-fixed-variant": "#962a00",
                        "surface-container": "#1a191b",
                        "on-primary": "#4c1d95",
                        "tertiary-fixed": "#ffd709",
                        "secondary-fixed": "#ffc4b3",
                        "surface-container-highest": "#262627",
                        "background": "#0e0e0f",
                        "on-tertiary-container": "#5b4b00",
                        "secondary": "#ff7346",
                        "on-secondary-container": "#fff6f3",
                        "on-error-container": "#ffa8a3",
                        "inverse-surface": "#fcf8f9",
                        "on-secondary": "#420d00",
                        "on-tertiary": "#655400",
                        "inverse-primary": "#6b21a8",
                        "inverse-on-surface": "#565556",
                        "on-primary-container": "#4c1d95",
                        "on-surface-variant": "#adaaab",
                        "primary-fixed": "#d8b4fe",
                        "error-dim": "#d7383b",
                        "on-primary-fixed-variant": "#4c1d95",
                        "surface-container-low": "#131314",
                        "on-tertiary-fixed": "#453900",
                        "on-error": "#490006",
                        "secondary-dim": "#ff7346",
                        "on-surface": "#ffffff",
                        "tertiary-fixed-dim": "#efc900",
                        "tertiary-dim": "#efc900",
                        "on-background": "#ffffff",
                        "surface": "#0e0e0f",
                        "primary-container": "#d8b4fe",
                        "surface-bright": "#2c2c2d",
                        "tertiary-container": "#ffd709",
                        "tertiary": "#ffe792",
                        "error-container": "#9f0519",
                        "surface-container-high": "#201f21",
                        "outline-variant": "#484849",
                        "on-secondary-fixed": "#651900",
                        "primary-fixed-dim": "#c084fc",
                        "primary": "#bf7af0",
                        "surface-tint": "#bf7af0",
                        "surface-variant": "#262627"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "fontFamily": {
                        "headline": ["Epilogue"],
                        "body": ["Manrope"],
                        "label": ["Manrope"]
                    }
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Manrope', sans-serif;
        }

        .font-headline {
            font-family: 'Epilogue', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        /* Custom Scrolling Reel Effect */
        .reel-column {
            animation: scroll-vertical 60s linear infinite;
        }

        .reel-column-reverse {
            animation: scroll-vertical-reverse 65s linear infinite;
        }

        @keyframes scroll-vertical {
            0% {
                transform: translateY(0);
            }

            100% {
                transform: translateY(-50%);
            }
        }

        @keyframes scroll-vertical-reverse {
            0% {
                transform: translateY(-50%);
            }

            100% {
                transform: translateY(0);
            }
        }

        .scrim-overlay {
            background: linear-gradient(to bottom, rgba(0, 0, 0, 0.9) 0%, rgba(14, 14, 15, 0.7) 40%, rgba(14, 14, 15, 0.7) 60%, rgba(0, 0, 0, 1) 100%);
        }

        .global-vignette {
            background: radial-gradient(circle, transparent 20%, rgba(0, 0, 0, 0.8) 100%);
        }

        .text-shadow-lg {
            text-shadow: 0 4px 12px rgba(0, 0, 0, 0.8);
        }

        /* Video Background Fixes */
        .video-foreground {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        .video-foreground iframe {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 100vw;
            height: 56.25vw;
            /* 16:9 aspect ratio */
            min-height: 100vh;
            min-width: 177.77vh;
            /* 16:9 aspect ratio */
            transform: translate(-50%, -50%);
        }
    </style>
</head>

